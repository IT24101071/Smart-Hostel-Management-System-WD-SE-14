# Optional API override in development.
# If set, this value wins over auto-detection (see constants/api.js).
# By default the app uses the same LAN host as Metro (Expo Go on a phone) when this is unset.
#
# Set EXPO_PUBLIC_API_URL only when you must override, for example:
# - Expo tunnel / cloud URL (auto host is unsuitable): use your PC LAN IP or a deployed API.
# - Android emulator without Expo host info: http://10.0.2.2:5000/api
# - Physical phone: http://YOUR_PC_LAN_IP:5000/api (same Wi‑Fi)
#
# Backend: cd backend && npm run dev (default port 5000)
#
# EXPO_PUBLIC_API_URL=http://192.168.1.42:5000/api
